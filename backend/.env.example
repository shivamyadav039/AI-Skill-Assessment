# ============ APP CONFIG ============
DEBUG=False
APP_NAME="AI Skill Assessment Agent"
APP_VERSION="0.1.0"

# ============ SERVER CONFIG ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ============ DATABASE CONFIG ============
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/skill_assessment
DB_ECHO=False

# ============ AI/LLM CONFIG (NVIDIA NIM) ============
# Get your key from: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# NVIDIA NIM model to use (OpenAI-compatible endpoint)
LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ============ NLP CONFIG ============
SPACY_MODEL=en_core_web_sm
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ============ ASSESSMENT CONFIG ============
MAX_TURNS_PER_SKILL=5
SKILL_ASSESSMENT_TIMEOUT_SECONDS=3600

# ============ RAG CONFIG ============
RAG_ENABLED=True
COURSE_DATABASE_URL=https://api.example.com/courses

# ============ CORS CONFIG ============
# For production, specify allowed origins: ["https://yourdomain.com"]
CORS_ORIGINS=["*"]

# ============ LOGGING ============
LOG_LEVEL=INFO
