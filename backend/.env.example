# ============ APP CONFIG ============
DEBUG=False
APP_NAME="AI Skill Assessment Agent"
APP_VERSION="0.1.0"

# ============ SERVER CONFIG ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ============ DATABASE CONFIG ============
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/skill_assessment
DB_ECHO=False

# ============ AI/LLM CONFIG ============
# Choose one: Claude (Anthropic) or GPT (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

GEMINI_API_KEY=AIzaSyAzd-eQmEB5C7_IxP4Vm5wRQjR589T9Vqk


# Model selection
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ============ NLP CONFIG ============
SPACY_MODEL=en_core_web_sm
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ============ ASSESSMENT CONFIG ============
MAX_TURNS_PER_SKILL=5
SKILL_ASSESSMENT_TIMEOUT_SECONDS=3600

# ============ RAG CONFIG ============
RAG_ENABLED=True
COURSE_DATABASE_URL=https://api.example.com/courses

# ============ CORS CONFIG ============
# For production, specify allowed origins: ["https://yourdomain.com"]
CORS_ORIGINS=["*"]

# ============ LOGGING ============
LOG_LEVEL=INFO
